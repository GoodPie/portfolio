{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**", ".astro/**"],
      "inputs": ["src/**", "public/**", "astro.config.*", "tsconfig.json", "tailwind.config.*"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "check": {
      "dependsOn": ["build"],
      "outputs": []
    }
  }
}
