---
import { Button } from "@goodpie/ui/components/button";
import FadeIn from "@/components/animations/FadeIn";
import ExternalLinkIcon from "@/components/icons/ExternalLinkIcon.astro";
import Section from "@/components/Section.astro";
import SectionLabel from "@/components/SectionLabel.astro";
---

<Section>
  <SectionLabel number="04" label="Contact" />

  <FadeIn client:visible direction="up">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="mb-4 font-serif text-4xl leading-tight md:text-5xl lg:text-6xl">
        Let's build something<br />
        <em class="text-teal italic">together.</em>
      </h2>

      <p class="text-muted-foreground mb-8 leading-relaxed">
        Always open to discussing new projects, opportunities, or just chatting about technology.
      </p>

      <a href="mailto:contact@brandynbritton.com">
        <Button
          size="lg"
          className="bg-teal text-background hover:bg-teal/90 pulse-glow cursor-pointer font-medium"
        >
          Message Me
          <ExternalLinkIcon size={16} class="ml-2" />
        </Button>
      </a>
    </div>
  </FadeIn>
</Section>
