---
import LineReveal from "@/components/animations/LineReveal";

interface Props {
  number: string;
  label: string;
}

const { number, label } = Astro.props;
---

<div class="mb-12 flex items-center gap-4">
  <span class="text-teal text-sm font-medium">{number}</span>
  <span class="text-muted-foreground text-sm font-medium tracking-widest uppercase">
    {label}
  </span>
  <LineReveal client:visible className="bg-border h-px flex-1" />
</div>
