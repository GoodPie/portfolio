---
import type { Experience } from "@/data/experience";
import StaggeredBadges from "@/components/animations/StaggeredBadges";
import ExternalLinkIcon from "@/components/icons/ExternalLinkIcon.astro";

interface Props {
  experience: Experience;
}

const { experience } = Astro.props;
---

<div class="mt-12 grid grid-cols-1 lg:grid-cols-[auto_1fr] lg:gap-16">
  <div
    class="text-muted-foreground/10 font-serif text-8xl leading-none font-light select-none lg:text-9xl"
  >
    {experience.id}
  </div>

  <div class="space-y-4">
    <div class="text-muted-foreground text-sm tracking-wide">
      {experience.dateRange}
    </div>

    <h3 class="font-serif text-2xl lg:text-3xl">
      {experience.title}
    </h3>

    <a
      href={experience.companyUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-teal inline-flex items-center gap-1 hover:underline"
    >
      {experience.company}
      <ExternalLinkIcon size={14} class="translate-y-px" />
    </a>

    <p class="text-muted-foreground max-w-2xl leading-relaxed">
      {experience.description}
    </p>

    <StaggeredBadges
      client:visible
      technologies={experience.technologies}
      className="flex flex-wrap gap-2 pt-2"
    />
  </div>
</div>
